// Dense MLP classifier (784->512->256->128->10)
// Note: despite the filename, this uses dense `layers` (fully-connected), not Conv2D.
// Conv2D is not supported in compile-train today.
// This file runs correctly with: volta run / volta compile-train (MLP path)

model cnn_classifier
    layers 784 512 256 128 10
    activation relu

dataset mnist_synthetic
    type synthetic
    batch 64

train cnn_classifier on mnist_synthetic
    epochs 50
    optimizer sgd
    lr 0.01
    device cpu
