// Dense MLP with GELU activation (256->1024->256)
// Note: despite the filename, this is a dense feedforward network, not a transformer.
// It does not use MultiHeadAttention. It runs correctly with volta compile-train (MLP path).

model transformer_ffn
    layers 256 1024 256
    activation gelu

dataset synthetic_seq
    type synthetic
    batch 32

train transformer_ffn on synthetic_seq
    epochs 50
    optimizer adam
    lr 0.0001
    device cpu
