// Dense MLP (512->512->512)
// Note: despite the filename, this has no residual connections -- it is a standard MLP.
// It runs correctly with volta compile-train (MLP path).

model resnet_block
    layers 512 512 512
    activation relu

dataset synthetic_features
    type synthetic
    batch 64

train resnet_block on synthetic_features
    epochs 50
    optimizer sgd
    lr 0.01
    device cpu
